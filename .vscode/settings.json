{
  "terminal.integrated.env.linux": {
    "ROCM_PATH": "/opt/rocm",
    "HIP_PATH": "/opt/rocm",
    "PATH": "/opt/rocm/bin:${env:PATH}",
    "LD_LIBRARY_PATH": "/opt/rocm/lib:${env:LD_LIBRARY_PATH}"
  },
  "cmake.configureEnvironment": {
    "ROCM_PATH": "/opt/rocm",
    "HIP_PATH": "/opt/rocm"
  },
  "cmake.configureArgs": [
    "-DUSE_ROCM=ON"
  ],
  "cmake.sourceDirectory": "/home/kevin/Projects/opennlp-gpu/src/main/cpp",
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.debug.settings.onBuildFailureProceed": true,
  "powershell.powerShellDefaultVersion": "PowerShell (x64)",
  "terminal.integrated.defaultProfile.linux": "bash",
  "chat.tools.autoApprove": true,
  "chat.agent.maxRequests": 100,
  "github.copilot.editor.enableAutoCompletions": true,
  "github.copilot.chat.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.advanced": {
    "temperature": 0.3,
    "top_p": 1,
    "listCount": 10
  },
  "git.commitMessageConvention": "conventional",
  "git.enableSmartCommit": true,
  "git.suggestSmartCommit": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "workbench.editor.enablePreview": false,
  "github.copilot.chat.alternateGptPrompt.enabled": true,
  "chat.todoListTool.enabled": true,
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#153c70",
    "activityBar.background": "#153c70",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#d72873",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#153c70",
    "statusBar.background": "#0d2545",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#153c70",
    "statusBarItem.remoteBackground": "#0d2545",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#0d2545",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#0d254599",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#0d2545"
}
